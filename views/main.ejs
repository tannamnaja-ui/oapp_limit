<script>
// ── Day checkbox: เลือกทั้งหมด / ล้างทั้งหมด ─────────────────────────────
function toggleAllDays() {
  const checks = [...document.querySelectorAll('.day-check')];
  const hasAny = checks.some(c => c.checked);
  checks.forEach(c => c.checked = !hasAny);
  updateToggleDaysBtn();
}
function updateToggleDaysBtn() {
  const btn = document.getElementById('toggleDaysBtn');
  if (!btn) return;
  const hasAny = [...document.querySelectorAll('.day-check')].some(c => c.checked);
  if (hasAny) {
    btn.innerHTML = '<i class="bi bi-x-circle me-1"></i>ล้างทั้งหมด';
    btn.style.borderColor = '#C0392B';
    btn.style.color       = '#C0392B';
  } else {
    btn.innerHTML = '<i class="bi bi-check2-all me-1"></i>เลือกทั้งหมด';
    btn.style.borderColor = '#27AE60';
    btn.style.color       = '#27AE60';
  }
}

// ── Thai day name from YYYY-MM-DD string ─────────────────────────────────
function thaiDayJS(v) {
  if (!v) return '';
  const [y,m,d] = String(v).substring(0,10).split('-').map(Number);
  if (!y) return '';
  return ['อาทิตย์','จันทร์','อังคาร','พุธ','พฤหัสบดี','ศุกร์','เสาร์'][new Date(y,m-1,d).getDay()];
}

// ── Time input helpers ────────────────────────────────────────────────────
// กรองเฉพาะตัวเลข แล้วใส่ : อัตโนมัติ → "083000" → "08:30:00"
function autoFmtTime(el) {
  let v = el.value.replace(/[^0-9]/g, '');         // เอาเฉพาะตัวเลข
  if (v.length > 6) v = v.substring(0, 6);
  let out = '';
  if (v.length >= 1) out = v.substring(0, Math.min(2, v.length));
  if (v.length >= 3) out += ':' + v.substring(2, Math.min(4, v.length));
  if (v.length >= 5) out += ':' + v.substring(4, 6);
  el.value = out;
}

// ตรวจสอบรูปแบบเวลาเมื่อ blur
function validateTime(el) {
  const v = el.value.trim();
  el.classList.remove('is-invalid', 'is-valid');
  if (!v) return;
  const ok = /^([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$/.test(v);
  el.classList.toggle('is-invalid', !ok);
  el.title = ok ? '' : 'รูปแบบไม่ถูกต้อง ต้องเป็น HH:MM:SS เช่น 08:30:00';
}

// คืนค่า HH:MM:SS หรือ null (ใช้ก่อน fetch)
function getTimeVal(id) {
  const v = document.getElementById(id).value.trim();
  if (!v) return null;
  // ถ้ากรอกแค่ HH:MM → เติม :00 อัตโนมัติ
  if (/^\d{1,2}:\d{2}$/.test(v)) return v + ':00';
  return v;
}

// ── Flatpickr date pickers ────────────────────────────────────────────────
let fpFrom, fpTo, fpStart, fpEnd, fpModal;
let tsClinic, tsFClinic, tsMClinic;
document.addEventListener('DOMContentLoaded', () => {
  // Flatpickr
  const fpOpts = { dateFormat:'Y-m-d', altInput:true, altFormat:'d/m/Y',
                   locale:{ firstDayOfWeek:1 }, allowInput:true };
  fpFrom  = flatpickr('#fDateFrom', fpOpts);
  fpTo    = flatpickr('#fDateTo',   fpOpts);
  fpStart = flatpickr('#startDate', fpOpts);
  fpEnd   = flatpickr('#endDate',   fpOpts);
  fpModal = flatpickr('#mDate',     fpOpts);

  // Tom Select — searchable clinic dropdowns
  const tsOpts = {
    create: false, allowEmptyOption: true,
    placeholder: '-- เลือกคลินิก --',
    searchField: ['text','value'],
    maxOptions: 500
  };
  tsFClinic = new TomSelect('#fClinic',   tsOpts);
  tsClinic  = new TomSelect('#clinicSel', tsOpts);
  tsMClinic = new TomSelect('#mClinic',   tsOpts);

  // init bulk bar state จาก server-rendered rows
  updateBulkBar();
});

// ── Row selection ─────────────────────────────────────────────────────────
let selRow = null, selData = null;
function selectRow(tr, data) {
  if (selRow) selRow.classList.remove('row-sel');
  selRow = tr; selData = data;
  tr.classList.add('row-sel');
  // Fill form with selected row data
  if (data) {
    if (tsClinic) tsClinic.setValue(data.oapp_clinic || ''); else document.getElementById('clinicSel').value = data.oapp_clinic || '';
    document.getElementById('limitCount').value  = data.oapp_limit  || '';
    document.getElementById('noteText').value    = data.limit_note  || '';
    if (data.oapp_date) {
      // data.oapp_date เป็น string 'YYYY-MM-DD' จาก TO_CHAR
      const iso = String(data.oapp_date).substring(0,10);
      fpStart.setDate(iso, true);
      fpEnd.setDate(iso, true);
    }
  }
}

// ── List navigation ───────────────────────────────────────────────────────
function listNav(dir) {
  const rows = [...document.querySelectorAll('#recordBody tr[data-id]')];
  if (!rows.length) return;
  if (!selRow) { rows[0].click(); return; }
  const i = rows.indexOf(selRow);
  ({first:()=>rows[0].click(), last:()=>rows[rows.length-1].click(),
    prev:()=>rows[Math.max(0,i-1)].click(),
    next:()=>rows[Math.min(rows.length-1,i+1)].click()})[dir]();
}

// ── Delete ────────────────────────────────────────────────────────────────
async function deleteSelected() {
  if (!selRow || !selData) { showAlert('warning','กรุณาเลือกรายการก่อน'); return; }
  if (!confirm('ต้องการลบรายการที่เลือกหรือไม่?')) return;
  try {
    const res  = await fetch(`/api/records/${selData.oapp_limit_id}`, { method:'DELETE' });
    const data = await res.json();
    if (data.ok) {
      selRow.remove(); selRow = null; selData = null;
      updateCount();
      showAlert('success','ลบรายการเรียบร้อยแล้ว');
    } else {
      showAlert('danger','ลบล้มเหลว: ' + data.msg);
    }
  } catch(e) { showAlert('danger','เกิดข้อผิดพลาด: ' + e.message); }
}
function updateCount() {
  const n = document.querySelectorAll('#recordBody tr[data-id]').length;
  document.getElementById('recCount').textContent = n + ' รายการ';
}

// ── Filter ────────────────────────────────────────────────────────────────
async function filterRecords() {
  const df = document.getElementById('fDateFrom').value;
  const dt = document.getElementById('fDateTo').value;
  const cl = document.getElementById('fClinic').value;

  const btn = document.querySelector('[onclick="filterRecords()"]');
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>กำลังค้นหา...';
  btn.disabled = true;

  try {
    const qs = new URLSearchParams();
    if (df) qs.set('date_from', df);
    if (dt) qs.set('date_to',   dt);
    if (cl) qs.set('clinic',    cl);

    const res  = await fetch('/api/records?' + qs.toString());
    const data = await res.json();

    if (!data.ok) { showAlert('danger', 'ค้นหาล้มเหลว: ' + data.msg); return; }
    renderTable(data.records);
  } finally {
    btn.innerHTML = '<i class="bi bi-search me-1"></i>ค้นหา';
    btn.disabled  = false;
  }
}

function clearFilter() {
  fpFrom.clear(); fpTo.clear();
  if (tsFClinic) tsFClinic.setValue(''); else document.getElementById('fClinic').value = '';
  filterRecords();
}

// ── Render table from API response ────────────────────────────────────────
function renderTable(records) {
  const tbody = document.getElementById('recordBody');
  selRow = null; selData = null;

  const chkAll = document.getElementById('chkAll');
  if (chkAll) chkAll.checked = false;
  updateBulkBar();

  if (!records || records.length === 0) {
    tbody.innerHTML = `<tr id="noDataRow">
      <td colspan="12" class="text-center py-5" style="color:#5D7080;font-size:1rem">
        <i class="bi bi-inbox me-2"></i>&lt;No data to display&gt;
      </td></tr>`;
    document.getElementById('recCount').textContent = '0 รายการ';
    return;
  }

  const fmtD = (v) => {
    if (!v) return '';
    try {
      let d;
      if (typeof v === 'string' && /^\d{4}-\d{2}-\d{2}/.test(v)) {
        const [y,m,day] = v.substring(0,10).split('-').map(Number);
        d = new Date(y, m-1, day);        // local parse — ไม่ shift timezone
      } else { d = new Date(v); }
      if (isNaN(d)) return String(v);
      return `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}/${d.getFullYear()}`;
    } catch(_){ return String(v); }
  };
  const fmtT = (v) => {
    if (!v) return '';
    if (typeof v === 'string') {
      const p = v.split(':');
      const h = (p[0]||'00').padStart(2,'0');
      const m = (p[1]||'00').padStart(2,'0');
      const s = (p[2]||'00').padStart(2,'0');
      return `${h}:${m}:${s}`;
    }
    return String(v);
  };

  tbody.innerHTML = records.map((r,i) => {
    const rowJson = JSON.stringify(r).replace(/"/g,'&quot;');
    return `
    <tr data-id="${r.oapp_limit_id||i}" data-row="${rowJson}" style="cursor:pointer"
        onclick="selectRowJS(this,${JSON.stringify(JSON.stringify(r))})">
      <td class="text-center" onclick="event.stopPropagation()">
        <input type="checkbox" class="form-check-input row-check"
               data-id="${r.oapp_limit_id||i}" onchange="updateBulkBar()">
      </td>
      <td class="text-center fw-semibold">${i+1}</td>
      <td>${fmtD(r.oapp_date)}</td>
      <td class="text-center" style="color:#5D3A9B;font-weight:600">${thaiDayJS(r.oapp_date)}</td>
      <td class="text-center fw-semibold" style="color:#1A4F72">${r.oapp_clinic||''}</td>
      <td style="font-size:0.88rem">${r.clinic_name||''}</td>
      <td class="text-center fw-bold" style="color:#1A4F72">${r.oapp_limit||''}</td>
      <td>${fmtT(r.start_time)}</td>
      <td>${fmtT(r.end_time)}</td>
      <td class="text-center">${r.check_time||''}</td>
      <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
          title="${r.limit_note||''}">${r.limit_note||''}</td>
      <td class="text-center">
        <button class="btn btn-xs"
                style="background:#2471A3;color:#fff;border:none;border-radius:4px;padding:2px 7px"
                title="แก้ไขรายการนี้"
                onclick="event.stopPropagation();openModal(JSON.parse(this.closest('tr').dataset.row))">
          <i class="bi bi-pencil-square"></i>
        </button>
      </td>
    </tr>`;
  }).join('');

  document.getElementById('recCount').textContent = records.length + ' รายการ';
  updateBulkBar();
}

function selectRowJS(tr, jsonStr) {
  selectRow(tr, JSON.parse(jsonStr));
}

// ── Form ──────────────────────────────────────────────────────────────────
function clearForm() {
  ['startTime','endTime','limitCount','noteText'].forEach(id=>{
    const el = document.getElementById(id); if (el) el.value = '';
  });
  fpStart.clear(); fpEnd.clear();
  document.getElementById('checkTime').checked = false;
  if (tsClinic) tsClinic.setValue(''); else document.getElementById('clinicSel').value = '';
  document.getElementById('weekSel').value = '';
  document.querySelectorAll('.day-check').forEach(cb => cb.checked = false);
  updateToggleDaysBtn();
  if (selRow) selRow.classList.remove('row-sel');
  selRow = null; selData = null;
}

// ── Collect form values ───────────────────────────────────────────────────
function getFormValues() {
  return {
    clinic:     document.getElementById('clinicSel').value,
    start:      document.getElementById('startDate').value,
    end:        document.getElementById('endDate').value,
    days:       [...document.querySelectorAll('.day-check:checked')].map(c=>c.value),
    week:       document.getElementById('weekSel').value,
    limit:      document.getElementById('limitCount').value,
    start_time:  getTimeVal('startTime'),
    end_time:    getTimeVal('endTime'),
    check_time:  document.getElementById('checkTime').checked ? 'Y' : '0',
    note:       document.getElementById('noteText').value,
    noHoliday:  false
  };
}

// ── Preview → Confirm → Insert ────────────────────────────────────────────
async function createRecords() {
  const f = getFormValues();
  if (!f.clinic)           { showAlert('warning','กรุณาเลือกคลินิก'); return; }
  if (!f.start || !f.end)  { showAlert('warning','กรุณาระบุวันที่เริ่มต้นและสิ้นสุด'); return; }
  if (!f.days.length)      { showAlert('warning','กรุณาเลือกอย่างน้อย 1 วัน'); return; }
  if (!f.limit || isNaN(parseInt(f.limit)))
                           { showAlert('warning','กรุณาระบุจำนวนจำกัด'); return; }

  // Step 1: preview
  const prev = await fetch('/api/preview-dates', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ start:f.start, end:f.end, days:f.days, week:f.week })
  });
  const pd = await prev.json();
  if (!pd.ok || !pd.dates.length) {
    showAlert('warning','ไม่พบวันที่ตรงตามเงื่อนไขที่เลือก'); return;
  }

  // Step 2: confirm
  const clinicTxt = document.getElementById('clinicSel').selectedOptions[0]?.text || f.clinic;
  // แปลง yyyy-mm-dd → dd/mm/yyyy สำหรับ confirm dialog
  const toThai = iso => {
    if (!iso) return '';
    const [y,m,d] = iso.split('-');
    return `${d}/${m}/${y}`;
  };
  const previewDates = pd.dates.slice(0,10).map(toThai).join('\n') +
                       (pd.dates.length>10 ? `\n...อีก ${pd.dates.length-10} วัน` : '');
  const ok = confirm(
    `══ ยืนยันการสร้างรายการ ══\n\n` +
    `คลินิก     : ${clinicTxt}\n` +
    `จำนวนจำกัด : ${f.limit} ราย/slot\n` +
    `เวลา       : ${f.start_time||'-'} — ${f.end_time||'-'}\n` +
    `จำนวนวัน   : ${pd.count} วัน\n\n` +
    `รายการวันที่ :\n${previewDates}\n\n` +
    `กด OK เพื่อยืนยันการ Insert ${pd.count} รายการ`
  );
  if (!ok) return;

  // Step 3: insert
  const btn = document.querySelector('[onclick="createRecords()"]');
  const orig = btn.innerHTML;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>กำลังสร้าง...';
  btn.disabled = true;

  try {
    const res  = await fetch('/api/create-records', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify(f)
    });
    const data = await res.json();
    showAlert(data.ok ? 'success' : 'danger', data.msg);
    if (data.ok) {
      clearForm();
      // Set filter to date range just inserted so user can see new records
      if (data.filter) {
        if (data.filter.date_from) fpFrom.setDate(data.filter.date_from, true); else fpFrom.clear();
        if (data.filter.date_to)   fpTo.setDate(data.filter.date_to,   true); else fpTo.clear();
        if (tsFClinic) tsFClinic.setValue(data.filter.clinic || ''); else document.getElementById('fClinic').value = data.filter.clinic || '';
      }
      filterRecords();
    }
  } finally {
    btn.innerHTML = orig;
    btn.disabled  = false;
  }
}

function saveData() { showAlert('info','ใช้ปุ่ม "แก้ไข" บนแถบรายการเพื่อแก้ไขข้อมูล'); }

// ── Modal: เพิ่ม / แก้ไขรายการรายวัน ────────────────────────────────────
// rowData = null → เพิ่มใหม่ | rowData = object → แก้ไข
function openModal(rowData = null) {
  const isEdit  = rowData !== null;
  const delBtn  = document.getElementById('mDeleteBtn');
  document.getElementById('modalTitleTxt').textContent = isEdit ? 'แก้ไขรายการ' : 'เพิ่มรายการใหม่';
  delBtn.classList.toggle('d-none', !isEdit);

  if (isEdit) {
    document.getElementById('mId').value        = rowData.oapp_limit_id || '';
    fpModal.setDate(String(rowData.oapp_date||'').substring(0,10), true);
    if (tsMClinic) tsMClinic.setValue(rowData.oapp_clinic || ''); else document.getElementById('mClinic').value = rowData.oapp_clinic || '';
    document.getElementById('mLimit').value     = rowData.oapp_limit   ?? '0';
    document.getElementById('mStartTime').value = rowData.start_time   || '';
    document.getElementById('mEndTime').value   = rowData.end_time     || '';
    document.getElementById('mCheck').checked   = rowData.check_time   === 'Y';
    document.getElementById('mNote').value      = rowData.limit_note   || '';
  } else {
    document.getElementById('mId').value        = '';
    fpModal.clear();
    if (tsMClinic) tsMClinic.setValue(''); else document.getElementById('mClinic').value = '';
    document.getElementById('mLimit').value     = '0';
    document.getElementById('mStartTime').value = '';
    document.getElementById('mEndTime').value   = '';
    document.getElementById('mCheck').checked   = false;
    document.getElementById('mNote').value      = '';
  }
  document.getElementById('modalAlert').classList.add('d-none');
  new bootstrap.Modal(document.getElementById('editModal')).show();
}

async function deleteFromModal() {
  const id = document.getElementById('mId').value;
  if (!id) return;
  if (!confirm('ต้องการลบรายการนี้หรือไม่?')) return;
  try {
    const res  = await fetch(`/api/records/${id}`, { method:'DELETE' });
    const data = await res.json();
    if (data.ok) {
      showAlert('success','ลบรายการเรียบร้อยแล้ว');
      const eModal = document.getElementById('editModal');
      eModal.addEventListener('hidden.bs.modal', () => filterRecords(), { once: true });
      bootstrap.Modal.getInstance(eModal).hide();
    } else {
      setModalAlert('danger','ลบล้มเหลว: ' + data.msg);
    }
  } catch(e) { setModalAlert('danger','เกิดข้อผิดพลาด: '+e.message); }
}

async function saveRecord() {
  const id      = document.getElementById('mId').value;
  const payload = {
    oapp_date:  document.getElementById('mDate').value,
    oapp_clinic:document.getElementById('mClinic').value,
    oapp_limit: document.getElementById('mLimit').value,
    start_time: getTimeVal('mStartTime'),
    end_time:   getTimeVal('mEndTime'),
    check_time: document.getElementById('mCheck').checked ? 'Y' : '0',
    limit_note: document.getElementById('mNote').value,
  };
  if (!payload.oapp_date)   { setModalAlert('danger','กรุณาระบุวันที่'); return; }
  if (!payload.oapp_clinic) { setModalAlert('danger','กรุณาเลือกคลินิก'); return; }

  const isEdit = !!id;
  const url    = isEdit ? `/api/records/${id}` : '/api/records';
  try {
    const res  = await fetch(url, {
      method: isEdit ? 'PUT' : 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.ok) {
      showAlert('success', data.msg);
      const eModal2 = document.getElementById('editModal');
      eModal2.addEventListener('hidden.bs.modal', () => filterRecords(), { once: true });
      bootstrap.Modal.getInstance(eModal2).hide();
    } else {
      setModalAlert('danger', data.msg);
    }
  } catch(e) { setModalAlert('danger','เกิดข้อผิดพลาด: '+e.message); }
}

// ── Bulk select ───────────────────────────────────────────────────────────
function getSelectedIds() {
  return [...document.querySelectorAll('.row-check:checked')].map(cb => cb.dataset.id);
}
function updateBulkBar() {
  const ids    = getSelectedIds();
  const cnt    = document.getElementById('bulkCount');
  const master = document.getElementById('masterCheck');
  const total  = document.querySelectorAll('.row-check').length;
  const has    = ids.length > 0;
  cnt.textContent = `${ids.length} รายการที่เลือก`;
  document.getElementById('bulkBar').classList.toggle('d-none', !has);
  // master checkbox state
  if (master) {
    master.indeterminate = has && ids.length < total;
    master.checked       = total > 0 && ids.length === total;
  }
  // enable/disable action buttons
  const btnEdit = document.getElementById('btnBulkEdit');
  const btnDel  = document.getElementById('btnBulkDel');
  if (btnEdit) { btnEdit.disabled = !has; btnEdit.style.opacity = has ? '1' : '0.4'; }
  if (btnDel)  { btnDel.disabled  = !has; btnDel.style.opacity  = has ? '1' : '0.4'; }
  // sync chkAll in table header
  const chkAll = document.getElementById('chkAll');
  if (chkAll) { chkAll.indeterminate = has && ids.length < total; chkAll.checked = total > 0 && ids.length === total; }
}
function toggleMasterCheck() {
  const master = document.getElementById('masterCheck');
  const checks = document.querySelectorAll('.row-check');
  const allChecked = [...checks].every(cb => cb.checked);
  checks.forEach(cb => { cb.checked = !allChecked; });
  updateBulkBar();
}
function selectAll() {
  document.querySelectorAll('.row-check').forEach(cb => { cb.checked = true; });
  updateBulkBar();
}
function toggleSelectAll(chk) {
  document.querySelectorAll('.row-check').forEach(cb => { cb.checked = chk.checked; });
  updateBulkBar();
}
function clearSelection() {
  document.querySelectorAll('.row-check').forEach(cb => { cb.checked = false; });
  updateBulkBar();
}

// ── Bulk delete ───────────────────────────────────────────────────────────
async function bulkDelete() {
  const ids = getSelectedIds();
  if (!ids.length) return;
  if (!confirm(`ต้องการลบ ${ids.length} รายการที่เลือกหรือไม่?\nการดำเนินการนี้ไม่สามารถยกเลิกได้`)) return;
  try {
    const res  = await fetch('/api/records/bulk', {
      method:'DELETE', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ ids })
    });
    const data = await res.json();
    showAlert(data.ok ? 'success' : 'danger', data.msg);
    if (data.ok) { clearSelection(); filterRecords(); }
  } catch(e) { showAlert('danger','เกิดข้อผิดพลาด: '+e.message); }
}

// ── Bulk edit ─────────────────────────────────────────────────────────────
function openBulkEditModal() {
  const ids = getSelectedIds();
  if (!ids.length) return;
  document.getElementById('bulkEditTitle').textContent = `แก้ไข ${ids.length} รายการที่เลือก`;
  ['bApplyLimit','bApplyTime','bApplyCheck','bApplyNote'].forEach(id=>{
    document.getElementById(id).checked = false;
  });

  document.getElementById('bLimit').value     = '';
  document.getElementById('bStartTime').value = '';
  document.getElementById('bEndTime').value   = '';
  document.getElementById('bCheck').checked   = false;
  document.getElementById('bNote').value      = '';
  document.getElementById('bulkEditAlert').classList.add('d-none');
  new bootstrap.Modal(document.getElementById('bulkEditModal')).show();
}
async function saveBulkEdit() {
  const ids = getSelectedIds();
  const apply = {
    limit: document.getElementById('bApplyLimit').checked,
    time:  document.getElementById('bApplyTime').checked,
    check: document.getElementById('bApplyCheck').checked,
    note:  document.getElementById('bApplyNote').checked,
  };
  if (!Object.values(apply).some(Boolean)) {
    const el = document.getElementById('bulkEditAlert');
    el.className = 'alert alert-warning py-2 mb-3';
    el.textContent = 'กรุณาเลือกอย่างน้อย 1 ฟิลด์ที่ต้องการแก้ไข';
    el.classList.remove('d-none');
    return;
  }
  const fields = {
    oapp_limit: document.getElementById('bLimit').value,
    start_time: document.getElementById('bStartTime').value,
    end_time:   document.getElementById('bEndTime').value,
    check_time: document.getElementById('bCheck').checked ? 'Y' : '0',
    limit_note: document.getElementById('bNote').value,
  };
  try {
    const res  = await fetch('/api/records/bulk', {
      method:'PUT', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ ids, fields, apply })
    });
    const data = await res.json();
    if (data.ok) {
      showAlert('success', data.msg);
      clearSelection();
      const bModal = document.getElementById('bulkEditModal');
      bModal.addEventListener('hidden.bs.modal', () => filterRecords(), { once: true });
      bootstrap.Modal.getInstance(bModal).hide();
    } else {
      const el = document.getElementById('bulkEditAlert');
      el.className = 'alert alert-danger py-2 mb-3';
      el.textContent = data.msg;
      el.classList.remove('d-none');
    }
  } catch(e) {
    const el = document.getElementById('bulkEditAlert');
    el.className = 'alert alert-danger py-2 mb-3';
    el.textContent = 'เกิดข้อผิดพลาด: '+e.message;
    el.classList.remove('d-none');
  }
}

function setModalAlert(type, msg) {
  const el = document.getElementById('modalAlert');
  el.className = `alert alert-${type} py-2 mt-3`;
  el.textContent = msg;
}

// ── Alert ─────────────────────────────────────────────────────────────────
function showAlert(type, msg) {
  const el = document.getElementById('formAlert');
  el.className = `alert alert-${type} alert-dismissible fade show py-2 mx-3 mt-2`;
  document.getElementById('formAlertMsg').textContent = msg;
}
function hideAlert() {
  const el = document.getElementById('formAlert');
  el.classList.remove('show'); el.classList.add('d-none');
}

// ── Connection settings login ─────────────────────────────────────────────
function gotoConn() { openConnLogin(); }

function openConnLogin() {
  document.getElementById('connUser').value = '';
  document.getElementById('connPwd').value  = '';
  const al = document.getElementById('connAlert');
  al.className = 'd-none alert py-2 mb-3';
  al.textContent = '';
  bootstrap.Modal.getOrCreateInstance(document.getElementById('connLoginModal')).show();
  setTimeout(() => document.getElementById('connUser').focus(), 400);
}

async function submitConnLogin() {
  const username = document.getElementById('connUser').value.trim();
  const password = document.getElementById('connPwd').value;
  const al       = document.getElementById('connAlert');
  const btn      = document.getElementById('connLoginBtn');

  if (!username || !password) {
    al.className = 'alert alert-warning py-2 mb-3';
    al.textContent = 'กรุณากรอกชื่อผู้ใช้และรหัสผ่าน';
    return;
  }
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>กำลังตรวจสอบ…';
  try {
    const r    = await fetch('/api/conn-auth', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, password })
    });
    const data = await r.json();
    if (data.ok) {
      bootstrap.Modal.getInstance(document.getElementById('connLoginModal')).hide();
      window.location.href = '/connection';
      return;
    }
    if (data.reason === 'no_access') {
      bootstrap.Modal.getInstance(document.getElementById('connLoginModal')).hide();
      bootstrap.Modal.getOrCreateInstance(document.getElementById('noConnAccessModal')).show();
      return;
    }
    al.className = 'alert alert-danger py-2 mb-3';
    al.textContent = data.msg || 'ชื่อผู้ใช้หรือรหัสผ่านไม่ถูกต้อง';
  } catch(e) {
    al.className = 'alert alert-danger py-2 mb-3';
    al.textContent = 'เกิดข้อผิดพลาด: ' + e.message;
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-box-arrow-in-right me-1"></i>เข้าสู่ระบบ';
  }
}
</script>

<!-- ── Modal: เข้าสู่ระบบ ตั้งค่าการเชื่อมต่อ ─────────────────────────── -->
<div class="modal fade" id="connLoginModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
