    <div class="modal-content border-0 shadow-lg rounded-4">
      <div class="modal-header border-0 pb-0 justify-content-center pt-4">
        <div style="font-size:2.6rem;color:#1A5276;line-height:1">
          <i class="bi bi-gear-wide-connected"></i>
        </div>
      </div>
      <div class="modal-body px-4 pt-2 pb-2">
        <h5 class="text-center fw-bold mb-3" style="color:#1A5276">เข้าสู่ระบบ — ตั้งค่าการเชื่อมต่อ</h5>
        <div id="connAlert" class="d-none alert py-2 mb-3" style="font-size:0.92rem"></div>
