// Helper functions (EJS server-side)
function thaiDay(v) {
  if (!v) return '';
  const [y,m,d] = String(v).substring(0,10).split('-').map(Number);
  if (!y) return '';
  return ['อาทิตย์','จันทร์','อังคาร','พุธ','พฤหัสบดี','ศุกร์','เสาร์'][new Date(y,m-1,d).getDay()];
}
function fmtDate(v) {
  if (!v) return '';
  try {
    // รับ "2026-05-30" หรือ Date object
    let d;
    if (typeof v === 'string' && /^\d{4}-\d{2}-\d{2}/.test(v)) {
      // parse แบบ local เพื่อหลีกเลี่ยง timezone shift
      const [y,m,day] = v.substring(0,10).split('-').map(Number);
      d = new Date(y, m-1, day);
    } else {
      d = new Date(v);
    }
    if (isNaN(d)) return String(v);
    const dd = String(d.getDate()).padStart(2,'0');
    const mm = String(d.getMonth()+1).padStart(2,'0');
    return `${dd}/${mm}/${d.getFullYear()}`;
  } catch(_) { return String(v); }
}
function fmtTime(v) {
  if (!v) return '';
  // string เช่น "08:30:00" หรือ "08:30"
  if (typeof v === 'string') {
    const parts = v.split(':');
    const h = parts[0] || '00';
    const m = parts[1] || '00';
    const s = parts[2] || '00';
    return `${h.padStart(2,'0')}:${m.padStart(2,'0')}:${s.padStart(2,'0')}`;
  }
  // Duration object (MySQL TIME type)
  if (typeof v === 'object' && v !== null) {
    const h = String(Math.floor(v.hours||0)).padStart(2,'0');
    const m = String(v.minutes||0).padStart(2,'0');
    const s = String(v.seconds||0).padStart(2,'0');
    return `${h}:${m}:${s}`;
  }
  return String(v);
}
%>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
