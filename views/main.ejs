<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>oapp_limit — ข้อมูลการจำกัดนัด</title>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
  <style>
    /* layout helpers */
    body   { background-color:#B8D9EF!important; font-family:'Sarabun','Tahoma',sans-serif; }
    .split-left  { width:58%; min-width:380px; background-color:#C5DFEF; border-right:2px solid #4BBFA8; }
    .split-right { width:42%; background-color:#D0EEE8; }
    .filter-bar  { background-color:#1A5276; border-bottom:3px solid #0E3858; }
    .filter-bar label, .filter-bar span { color:#fff!important; }
    #fClinic + .ts-wrapper { width:320px!important; min-width:320px!important; }
    .ts-wrapper { min-width:0; }
    .filter-bar .form-control, .filter-bar .form-select {
      font-size:1rem!important; min-height:38px!important;
      border:1.5px solid #5DADE2; background:#EAF4FB;
    }
    /* table overrides */
    #recordTable thead th { background-color:#2471A3!important; color:#fff!important; font-size:0.9rem; padding:8px 10px; white-space:nowrap; }
    #recordTable tbody td { font-size:0.9rem; padding:7px 10px; color:#17202A; border-color:#C2DDEE; vertical-align:middle; }
    #recordTable tbody tr:nth-child(even) td { background-color:#DCF0FA; }
    #recordTable tbody tr:hover td  { background-color:#B8DDEF!important; cursor:pointer; }
    #recordTable tbody tr.row-sel td { background-color:#7EC8E3!important; font-weight:600; }
    /* count badge */
    .rec-count { background:#2471A3; color:#fff; border-radius:20px; padding:2px 12px; font-size:0.9rem; font-weight:600; }
  </style>
</head>
<body>
<div class="d-flex flex-column" style="height:100vh;overflow:hidden">

  <%/* ── Navbar ──────────────────────────────────────────────────────── */%>
  <div class="app-header d-flex align-items-center px-4 flex-shrink-0" style="min-height:52px">
    <i class="bi bi-hospital me-2 fs-5 text-white"></i>
    <span class="fw-bold text-white" style="font-size:1.1rem">ระบบจำกัดนัดคลินิก</span>
    <span class="ms-3 badge bg-light text-dark-blue">
      <i class="bi bi-person-circle me-1"></i><%= user %>
    </span>
    <div class="ms-auto d-flex gap-2">
      <a href="javascript:void(0)" onclick="gotoConn()" class="btn btn-medium-blue py-2">
        <i class="bi bi-gear me-1"></i>ตั้งค่าการเชื่อมต่อ
      </a>
      <a href="/logout" class="btn btn-danger py-2">
        <i class="bi bi-box-arrow-right me-1"></i>ออกจากระบบ
      </a>
    </div>
  </div>

  <%/* ── DB error banner ──────────────────────────────────────────────── */%>
  <% if (dbError) { %>
  <div class="alert alert-warning mb-0 rounded-0 py-2 text-center" style="font-size:0.95rem">
    <i class="bi bi-exclamation-triangle me-1"></i>
    DB Error: <%= dbError %>
    — <a href="javascript:void(0)" onclick="gotoConn()" class="fw-bold">ตั้งค่าการเชื่อมต่อ</a>
  </div>
  <% } %>

  <%/* ── Filter bar ───────────────────────────────────────────────────── */%>
  <div class="filter-bar d-flex align-items-center flex-wrap gap-3 px-4 py-2 flex-shrink-0">
    <span class="fw-bold" style="font-size:1.05rem;white-space:nowrap">
      <i class="bi bi-funnel-fill me-1"></i>กรองข้อมูล :
    </span>

    <div class="d-flex align-items-center gap-2">
      <label class="fw-bold" style="font-size:1rem;white-space:nowrap">วันที่เริ่ม</label>
      <div style="width:155px"><input type="date" id="fDateFrom" class="form-control w-100"></div>
    </div>

    <div class="d-flex align-items-center gap-2">
      <label class="fw-bold" style="font-size:1rem;white-space:nowrap">ถึง</label>
      <div style="width:155px"><input type="date" id="fDateTo" class="form-control w-100"></div>
    </div>

    <div class="d-flex align-items-center gap-2">
      <label class="fw-bold" style="font-size:1rem;white-space:nowrap">คลินิก</label>
      <select id="fClinic" class="form-select" style="width:320px">
        <option value="">— ทั้งหมด —</option>
        <% clinics.forEach(function(c){ %>
        <option value="<%= c.clinic||c[0] %>"><%= c.clinic||c[0] %> — <%= c.name||c[1] %></option>
        <% }) %>
      </select>
    </div>

    <button class="btn btn-warning fw-bold px-3" style="font-size:1rem;min-height:38px;color:#1A3A5C"
            onclick="filterRecords()">
      <i class="bi bi-search me-1"></i>ค้นหา
    </button>
    <button class="btn btn-light fw-semibold px-3" style="font-size:1rem;min-height:38px;color:#1A3A5C"
            onclick="clearFilter()">
      <i class="bi bi-x-circle me-1"></i>ล้าง
    </button>

    <span class="ms-auto rec-count" id="recCount"
          style="font-size:1rem;padding:4px 16px"><%= records.length %> รายการ</span>
  </div>

  <%/* ── Main split pane ──────────────────────────────────────────────── */%>
  <div class="d-flex flex-fill overflow-hidden">

    <%/* ── Left: data table ──────────────────────────────────────────── */%>
    <div class="split-left d-flex flex-column">

      <!-- Table toolbar -->
      <div class="list-toolbar d-flex align-items-center gap-1 px-2 border-bottom flex-wrap" style="background-color:#A0C8E0">
        <button class="btn btn-xs btn-toolbar-nav" onclick="listNav('first')" title="หน้าแรก">|◄</button>
        <button class="btn btn-xs btn-toolbar-nav" onclick="listNav('prev')"  title="ก่อนหน้า">◄</button>
        <button class="btn btn-xs btn-toolbar-nav" onclick="listNav('next')"  title="ถัดไป">►</button>
        <button class="btn btn-xs btn-toolbar-nav" onclick="listNav('last')"  title="หน้าสุดท้าย">►|</button>
        <span class="border-start mx-2" style="height:20px;border-color:#93C6E0"></span>
        <button class="btn btn-xs" style="background:#27AE60;color:#fff;border:none;border-radius:4px;padding:3px 10px"
                title="เพิ่มรายการใหม่" onclick="openModal()">
          <i class="bi bi-plus-lg me-1"></i>เพิ่มรายการ
        </button>
      </div>

      <!-- Bulk action bar (hidden until rows selected) -->
      <div id="bulkBar" class="d-none d-flex align-items-center gap-2 px-3 py-2 flex-shrink-0"
           style="background:#FFF8E1;border-bottom:2px solid #F9CA24;font-size:0.93rem">
        <div class="form-check mb-0 d-flex align-items-center gap-2" style="cursor:pointer"
             onclick="toggleMasterCheck()">
          <input type="checkbox" id="masterCheck" class="form-check-input"
                 style="width:1.2em;height:1.2em;cursor:pointer" onclick="event.stopPropagation();toggleMasterCheck()">
          <label class="form-check-label fw-semibold" style="cursor:pointer;color:#1A4F72;white-space:nowrap">
            เลือก / ล้างทั้งหมด
          </label>
        </div>
        <span class="border-start mx-1" style="height:20px;border-color:#F0C040"></span>
        <span class="fw-semibold" id="bulkCount" style="color:#7D4E00;white-space:nowrap">0 รายการที่เลือก</span>
        <button id="btnBulkEdit" class="btn btn-sm fw-semibold ms-2" disabled
                style="background:#E67E22;color:#fff;border:none;border-radius:6px;opacity:0.45"
                onclick="openBulkEditModal()">
          <i class="bi bi-pencil-fill me-1"></i>แก้ไขที่เลือก
        </button>
        <button id="btnBulkDel" class="btn btn-sm btn-danger fw-semibold" disabled
                style="border-radius:6px;opacity:0.45"
                onclick="bulkDelete()">
          <i class="bi bi-trash3-fill me-1"></i>ลบที่เลือก
        </button>
      </div>

      <!-- Table -->
      <div class="flex-fill overflow-auto">
        <table class="table table-hover mb-0 w-100" id="recordTable" style="background:#F0F8FE">
          <thead style="position:sticky;top:0;z-index:1">
            <tr>
              <th style="width:34px" class="text-center">
                <input type="checkbox" id="chkAll" class="form-check-input" onclick="toggleSelectAll(this)">
              </th>
              <th style="width:38px" class="text-center">#</th>
              <th style="width:98px">วันที่</th>
              <th style="width:78px" class="text-center">วัน</th>
              <th style="width:60px" class="text-center">คลินิก</th>
              <th style="min-width:110px">ชื่อคลินิก</th>
              <th style="width:60px" class="text-center">จำกัด</th>
              <th style="width:80px">เริ่ม</th>
              <th style="width:80px">สิ้นสุด</th>
              <th style="width:55px" class="text-center">check</th>
              <th>หมายเหตุ</th>
              <th style="width:48px" class="text-center"></th>
            </tr>
          </thead>
          <tbody id="recordBody">
            <% if (records && records.length > 0) { %>
              <% records.forEach(function(r, i){ %>
              <tr data-id="<%= r.oapp_limit_id||i %>"
                  data-row="<%- JSON.stringify(r).replace(/"/g,'&quot;') %>"
                  onclick="selectRow(this,<%- JSON.stringify(r) %>)">
                <td class="text-center" onclick="event.stopPropagation()">
                  <input type="checkbox" class="form-check-input row-check"
                         data-id="<%= r.oapp_limit_id||i %>" onchange="updateBulkBar()">
                </td>
                <td class="text-center fw-semibold"><%= i+1 %></td>
                <td><%= fmtDate(r.oapp_date) %></td>
                <td class="text-center" style="color:#5D3A9B;font-weight:600"><%= thaiDay(r.oapp_date) %></td>
                <td class="text-center fw-semibold" style="color:#1A4F72"><%= r.oapp_clinic||'' %></td>
                <td style="font-size:0.88rem"><%= r.clinic_name||'' %></td>
                <td class="text-center fw-bold" style="color:#1A4F72"><%= r.oapp_limit||'' %></td>
                <td><%= fmtTime(r.start_time) %></td>
                <td><%= fmtTime(r.end_time) %></td>
                <td class="text-center"><%= r.check_time||'' %></td>
                <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                    title="<%= r.limit_note||'' %>"><%= r.limit_note||'' %></td>
                <td class="text-center">
                  <button class="btn btn-xs"
                          style="background:#2471A3;color:#fff;border:none;border-radius:4px;padding:2px 7px"
                          title="แก้ไขรายการนี้"
                          onclick="event.stopPropagation();openModal(JSON.parse(this.closest('tr').dataset.row))">
                    <i class="bi bi-pencil-square"></i>
                  </button>
                </td>
              </tr>
              <% }) %>
            <% } else { %>
            <tr id="noDataRow">
              <td colspan="12" class="text-center py-5" style="color:#5D7080;font-size:1rem">
                <i class="bi bi-inbox me-2"></i>&lt;No data to display&gt;
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

    </div><!-- /left -->

    <%/* ── Right: create / edit form ─────────────────────────────────── */%>
    <div class="split-right d-flex flex-column">

      <!-- Right header -->
      <div class="right-panel-header d-flex align-items-center px-4 flex-shrink-0">
        <i class="bi bi-calendar-plus me-2 fs-5 text-white"></i>
        <span class="fw-bold text-white" style="font-size:1rem">กำหนดการจำกัดนัดตามช่วงเวลา</span>
        <button class="ms-auto btn btn-success py-2 px-3 fw-bold"
                style="font-size:0.95rem" onclick="createRecords()">
          <i class="bi bi-play-fill me-1"></i>สร้างรายการ
        </button>
      </div>

      <!-- Form alert -->
      <div id="formAlert" class="alert alert-dismissible fade d-none mx-3 mt-2 py-2" role="alert">
        <span id="formAlertMsg"></span>
        <button type="button" class="btn-close" onclick="hideAlert()"></button>
      </div>

      <!-- Form (no scroll) -->
      <div class="flex-fill px-3 py-2 d-flex flex-column gap-2" style="overflow:hidden;font-size:0.88rem">

        <!-- กล่องข้อมูลหลัก -->
        <div style="background:rgba(255,255,255,0.55);border-radius:14px;border:1px solid rgba(78,196,166,0.4);padding:12px 14px;box-shadow:0 2px 8px rgba(14,124,106,0.08)">

          <!-- คลินิก -->
          <div class="row align-items-center mb-2">
            <label class="col-sm-4 col-form-label fw-semibold" style="font-size:0.85rem;color:#0B5E50">คลินิก</label>
            <div class="col-sm-8">
              <select id="clinicSel" class="form-select form-select-sm" style="border-radius:8px">
                <option value="">-- เลือกคลินิก --</option>
                <% clinics.forEach(function(c){ %>
                <option value="<%= c.clinic||c[0] %>"><%= c.clinic||c[0] %> — <%= c.name||c[1] %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <!-- วันที่ -->
          <div class="row align-items-center mb-2">
            <label class="col-sm-4 col-form-label fw-semibold" style="font-size:0.85rem;color:#0B5E50">วันที่เริ่มต้น</label>
            <div class="col-sm-4">
              <input type="date" id="startDate" class="form-control form-control-sm" style="border-radius:8px">
            </div>
            <label class="col-sm-1 col-form-label fw-semibold text-center" style="font-size:0.85rem">ถึง</label>
            <div class="col-sm-3">
              <input type="date" id="endDate" class="form-control form-control-sm" style="border-radius:8px">
            </div>
          </div>

          <!-- สัปดาห์ที่ -->
          <div class="row align-items-center mb-2">
            <label class="col-sm-4 col-form-label fw-semibold" style="font-size:0.85rem;color:#0B5E50">สัปดาห์ที่</label>
            <div class="col-sm-4">
              <select id="weekSel" class="form-select form-select-sm" style="border-radius:8px">
                <option value="">None selected</option>
                <% [1,2,3,4,5].forEach(n=>{ %><option><%= n %></option><% }) %>
              </select>
            </div>
          </div>

          <!-- วัน -->
          <div class="row align-items-start mb-2">
            <label class="col-sm-4 col-form-label fw-semibold" style="font-size:0.85rem;color:#0B5E50">วัน</label>
            <div class="col-sm-8">
              <div style="background:#E8F8F4;border-radius:10px;border:1px solid #6DCBB8;padding:6px 10px">
                <div class="mb-1">
                  <button type="button" id="toggleDaysBtn" class="btn btn-sm"
                          style="font-size:0.76rem;background:#E8F8F4;border:1.5px solid #1AAB8A;color:#0B7A60;padding:1px 10px;border-radius:20px;font-weight:600"
                          onclick="toggleAllDays()">
                    <i class="bi bi-check2-all me-1"></i>เลือกทั้งหมด
                  </button>
                </div>
                <div class="row g-1">
                  <% [['mon','จันทร์'],['tue','อังคาร'],['wed','พุธ'],['thu','พฤหัสบดี'],
                      ['fri','ศุกร์'],['sat','เสาร์'],['sun','อาทิตย์']].forEach(function(d){ %>
                  <div class="col-4">
                    <div class="form-check mb-0">
                      <input class="form-check-input day-check" type="checkbox"
                             id="day_<%= d[0] %>" value="<%= d[0] %>"
                             onchange="updateToggleDaysBtn()" style="margin-top:2px">
                      <label class="form-check-label" for="day_<%= d[0] %>" style="font-size:0.82rem"><%= d[1] %></label>
                    </div>
                  </div>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>

          <!-- check_time -->
          <div class="row align-items-center mb-1">
            <div class="col-sm-4"></div>
            <div class="col-sm-8">
              <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" id="checkTime">
                <label class="form-check-label fw-semibold" for="checkTime" style="font-size:0.83rem;color:#0B5E50">check_time = Y</label>
              </div>
            </div>
          </div>

          <!-- เวลา -->
          <div class="row align-items-center mb-2">
            <label class="col-sm-4 col-form-label fw-semibold" style="font-size:0.85rem;color:#0B5E50">เวลาเริ่ม</label>
            <div class="col-sm-4">
              <input type="text" id="startTime" class="form-control form-control-sm text-center fw-semibold"
                     maxlength="8" placeholder="HH:MM:SS" style="border-radius:8px"
                     oninput="autoFmtTime(this)" onblur="validateTime(this)">
            </div>
            <label class="col-sm-1 col-form-label fw-semibold text-center" style="font-size:0.85rem">ถึง</label>
            <div class="col-sm-3">
              <input type="text" id="endTime" class="form-control form-control-sm text-center fw-semibold"
                     maxlength="8" placeholder="HH:MM:SS" style="border-radius:8px"
                     oninput="autoFmtTime(this)" onblur="validateTime(this)">
            </div>
          </div>

          <!-- จำนวนจำกัด -->
          <div class="row align-items-center mb-0">
            <label class="col-sm-4 col-form-label fw-semibold" style="font-size:0.85rem;color:#0B5E50">จำนวนจำกัด <span class="text-danger">*</span></label>
            <div class="col-sm-5">
              <div class="input-group input-group-sm">
                <input type="number" id="limitCount" class="form-control" min="0" placeholder="0" required
                       style="border-radius:8px 0 0 8px">
                <span class="input-group-text" style="font-size:0.82rem;border-radius:0 8px 8px 0">ราย/slot</span>
              </div>
            </div>
          </div>

        </div><!-- /กล่องข้อมูลหลัก -->

        <!-- กล่องหมายเหตุ (แยกออกมา) -->
        <div style="background:rgba(255,255,255,0.55);border-radius:14px;border:1.5px solid rgba(78,196,166,0.5);padding:10px 14px;box-shadow:0 2px 8px rgba(14,124,106,0.08)">
          <div class="d-flex align-items-center gap-2 mb-1">
            <i class="bi bi-chat-left-text" style="color:#0E7C6A;font-size:0.9rem"></i>
            <span class="fw-semibold" style="font-size:0.85rem;color:#0B5E50">หมายเหตุ</span>
          </div>
          <textarea id="noteText" class="form-control form-control-sm"
                    placeholder="หมายเหตุเพิ่มเติม..." rows="2"
                    style="resize:none;border-radius:8px;border-color:#6DCBB8"></textarea>
        </div>

      </div><!-- /form -->

    </div><!-- /right -->
  </div><!-- /split -->
<!-- ── Modal: แก้ไขหลายรายการพร้อมกัน ─────────────────────────────────── -->
<div class="modal fade" id="bulkEditModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width:500px">
    <div class="modal-content" style="border:2px solid #E67E22">
      <div class="modal-header py-2" style="background:#E67E22">
        <i class="bi bi-pencil-square text-white me-2 fs-5"></i>
        <span class="fw-bold text-white fs-6" id="bulkEditTitle">แก้ไขหลายรายการ</span>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="background:#FFF8F0">
        <p class="text-muted mb-3" style="font-size:0.88rem">
          <i class="bi bi-info-circle me-1"></i>
          ติ๊กช่องซ้ายมือเพื่อเลือกฟิลด์ที่ต้องการเปลี่ยน
        </p>
        <div id="bulkEditAlert" class="alert d-none py-2 mb-3" style="font-size:0.9rem"></div>

        <!-- จำนวนจำกัด -->
        <div class="row align-items-center mb-3">
          <div class="col-auto">
            <input type="checkbox" id="bApplyLimit" class="form-check-input" style="width:1.2em;height:1.2em">
          </div>
          <label class="col-sm-4 col-form-label fw-semibold">จำนวนจำกัด</label>
          <div class="col">
            <div class="input-group">
              <input type="number" id="bLimit" class="form-control" min="0" placeholder="0">
              <span class="input-group-text">ราย</span>
            </div>
          </div>
        </div>

        <!-- เวลาเริ่ม–สิ้นสุด -->
        <div class="row align-items-center mb-3">
          <div class="col-auto">
            <input type="checkbox" id="bApplyTime" class="form-check-input" style="width:1.2em;height:1.2em">
          </div>
          <label class="col-sm-4 col-form-label fw-semibold">เวลา</label>
          <div class="col">
            <div class="d-flex align-items-center gap-2">
              <input type="text" id="bStartTime" class="form-control text-center" maxlength="8" placeholder="HH:MM:SS" style="width:105px"
                     oninput="autoFmtTime(this)" onblur="validateTime(this)">
              <span class="fw-semibold">ถึง</span>
              <input type="text" id="bEndTime" class="form-control text-center" maxlength="8" placeholder="HH:MM:SS" style="width:105px"
                     oninput="autoFmtTime(this)" onblur="validateTime(this)">
            </div>
            <small class="text-muted">รูปแบบ 24 ชม. เช่น 08:30:00</small>
          </div>
        </div>

        <!-- check_time -->
        <div class="row align-items-center mb-3">
          <div class="col-auto">
